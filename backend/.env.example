# ─────────────────────────────────────────────────────────────────
#  Vamsee AI Backend – Environment Configuration
#  Copy this to .env and edit as needed.
# ─────────────────────────────────────────────────────────────────

# Application
APP_NAME="Vamsee AI Backend"
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# CORS – add your frontend origin(s) here
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Ollama ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# ─── Workspace sandbox ────────────────────────────────────────────
# Separate multiple paths with commas inside the JSON array
ALLOWED_WORKSPACE_ROOTS=["C:/Users/Vamsee/Projects","X:/Project-Buildings"]

# ─── Blocked terminal commands ─────────────────────────────────────
BLOCKED_COMMANDS=["rm","del","rmdir","rd","format","shutdown","reboot","restart","reg","regedit","net","netsh","taskkill","cipher","diskpart"]

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── Tesseract OCR ─────────────────────────────────────────────
# Uncomment and set if tesseract is not in your system PATH
# TESSERACT_PATH="C:/Program Files/Tesseract-OCR/tesseract.exe"
